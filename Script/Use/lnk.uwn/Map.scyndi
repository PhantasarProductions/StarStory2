	Void Cycles(int Cyc)
		For i=1,Cyc
			Graphics.Cls()
			MCall("FlowField.DrawScreen","nil")
			Graphics.Flip()
			Sys.WaitMinTicks()
			Events.Poll()
		End
	End
	
	Get String Leader
		return RPGParty[gint.Leader]
	End

	
	Init
		//table m
		m := {}
		//delegate idx(s,string key)
		ddef idx
			plua s
			string key
			s,key=infinity
			//Void f(para)
			ddef f
				para:=infinity
				para = para || "nil"
				Map["Script"](key,para)
			end
			return f
		end
		m.__index = idx
		MapScript = setmetatable({},m)
		//string MetaIndex(s,string key)
		ddef MetaIndex
			plua a
			string key
			a,key=infinity
			//CSayF("Remoye Map Meta Request: %s",key)
			//return ISGET.STRING("FLOW_FIELD",sprintf("FlowField.Map.KthuraMap.Meta[\"%s\"]",key))
			return Kthura.MetaData[key]
		end
		Meta = setmetatable({},{["__index"]=MetaIndex})
	end

