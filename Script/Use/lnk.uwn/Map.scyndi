	Void Schedule(String scriptfunction)
		MCall("FlowField.Schedule.Schedule",scriptfunction)
	End
	
	Void LoadMap(string Map)
		If Sys.StateName=="MAPSCRIPT"
			MCall("FlowField.Schedule.Add","LOAD:"..Map)
		Else
			MCall("FlowField.LoadMap",Map)
		End		
	End
	
	
	Void Load(string Map)
		LoadMap(Map)
	End
	
	Bool HasTag(string Tag)
		//Return ISGET.BOOL("FLOW_FIELD",sPrintF("FlowField.Map.CurLayer.HasTag(\"%s\")",Tag))
		return Kthura.HasObj(Tag)
	End
	
	Void BlockObj(string Tag)
		MCall("FlowField.Map.Block",Tag)
	End
	
	Void UnBlockObj(String Tag)
		MCall("FlowField.Map.UnBlock",Tag)
	End
	
	Void GoToMap(string aMap,string aLayer,string SpawnPoint,noclose,noopen)
		printf("\027[33mGoToMap\027[37m(\027[32m\"%s\"\027[37m,\027[32m\"%s\"027[37m,\027[32m\"%s\"\027[37m,\027[36m%s027[37m,\027[36m%s\027[37m)\027[0m\n",amap,alayer,spawnpoint,noclose,noopen)
		if !noclose
			CDLoading()
		End
		LoadMap(aMap)
		Schedule("LAYER:"..aLayer)
		Schedule("SPAWN:"..SpawnPoint)
		if !noopen
			Schedule(":OPENDOOR:")
		else
			CSay("No open request! So instant display and no open door first!")
		end
		Ach.Auto()
	End
	
	Void GoToMapPos(string aMap,string aLayer,Int X, Int Y)
		LoadMap(aMap)
		Schedule("LAYER:"..aLayer)
		Schedule("SPAWNPOS:"..X..","..Y)
	End

	
	Void GoToLayer(string aLayer, string SpawnPoint)
		for i=1,4
			If HasTag("PLAYER"..i)
				Map.Kill("PLAYER"..i,False)
			End
		End
		//MCall("FlowField.Map.SetLayer",aLayer)
		//ISSET("string","FLOW_FIELD","FlowField.Map.Layer",aLayer)
		Kthura.CurrentLayer=aLayer
		for c=1,4
			if RPGParty[c]!=""
				Map.Spawn("PLAYER"..c,SpawnPoint)
			end
		end
		Ach.Auto()
	End
	
	Void Spawn(string ActTag,a,b)
		Switch Lua.type(a)
			Case "string"
				CSayF("Spawning ActTag '%s' on spot '%s'",ActTag,a)
				MCall("FlowField.Map.CurLayer.Spawn",ActTag,a)
			Case "number"
				assert(Lua.type(b)=="number","n::Illegal spawn function call")
				CSayF("Spawning ActTag '%s' on coordinates (%4d,%4d)",ActTag,a,b)
				MCall("FlowField.Map.CurLayer.Spawn",ActTag,a,b)
			Default
				Lua.error("t::Illegal spawn function call")			
		End
	End
	
	Void SpawnPlayer(a,b)		
		Spawn("PLAYER1",a,b)
	End
	
	Void _Script(String Func,Infinity)
		
		//State.Call("MAPSCRIPT","MScript."..Func,"\""..Lua.tostring(Args).."\"")
